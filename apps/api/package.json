{
  "name": "@supacontext/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node ../../scripts/with-root-env.mjs tsx watch src/index.ts",
    "lint": "eslint . --max-warnings 0",
    "start": "node ../../scripts/with-root-env.mjs node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@supacontext/config": "workspace:*",
    "@supacontext/core": "workspace:*",
    "@supacontext/db": "workspace:*",
    "@supacontext/usage": "workspace:*",
    "fastify": "^5.6.2",
    "postgres": "^3.4.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@supacontext/eslint-config": "workspace:*",
    "@supacontext/tsconfig": "workspace:*"
  }
}
